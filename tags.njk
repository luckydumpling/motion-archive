---
layout: base.njk
pagination:
  data: collections.allTags
  size: 1
  alias: tag
permalink: /tags/{{ tag }}/
---
<div class="tag-page">
  <a href="/" class="back">
    <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,2 4,7 9,12"/></svg>
    All entries
  </a>
  <h1>{{ tag }}</h1>
  <div class="grid">
    {% for entry in collections.all %}
      {% if entry.data.layout == "entry.njk" and tag in entry.data.tags %}
        {% set thumb = entry.data.video_url | thumbnailFromUrl %}
        <a href="{{ entry.url }}" class="card">
          <div class="thumb">
            {% if entry.data.status == "unavailable" %}
              <div class="thumb-unavailable"><span>No longer available</span></div>
            {% elif thumb %}
              <img src="{{ thumb }}" alt="{{ entry.data.title }}" loading="lazy">
            {% else %}
              <div class="thumb-unavailable"><span>No preview</span></div>
            {% endif %}
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class="type-badge type-{{ entry.data.type }}">{{ entry.data.type }}</span>
              <span class="meta-dot"></span>
              <span class="meta-text">{{ entry.data.year }}</span>
              <span class="meta-dot"></span>
              <span class="meta-text">{{ entry.data.creator }}</span>
            </div>
            <div class="card-title">{{ entry.data.title }}</div>
            <div class="card-tags">
              {% for t in entry.data.tags %}
                <span class="card-tag">{{ t }}</span>
              {% endfor %}
            </div>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</div>
