---
layout: base.njk
---
{% set allTags = collections.allTags %}

<div class="filter-bar">
  <div class="filter-section">
    <div class="filter-label">Type</div>
    <div class="filter-row" id="type-filters">
      <button class="ftag active-type" data-type="all">All</button>
      <button class="ftag" data-type="tutorial">Tutorial</button>
      <button class="ftag" data-type="inspiration">Inspiration</button>
    </div>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-section">
    <div class="filter-label">Technique</div>
    <div class="filter-row" id="tech-filters">
      <button class="ftag active-tech" data-tech="all">All</button>
      {% for tag in allTags %}
        <button class="ftag" data-tech="{{ tag }}">{{ tag }}</button>
      {% endfor %}
    </div>
  </div>
  <div class="filter-divider"></div>
  <div class="filter-section">
    <div class="filter-label">Tool</div>
    <div class="filter-row" id="tool-filters">
      <button class="ftag active-tool" data-tool="all">All</button>
      <button class="ftag" data-tool="after-effects">After Effects</button>
      <button class="ftag" data-tool="touchdesigner">TouchDesigner</button>
    </div>
  </div>
  <div class="filter-divider"></div>
  <div class="count" id="count"></div>
</div>

<div class="grid" id="grid">
  {% for entry in collections.all %}
    {% if entry.data.layout == "entry.njk" %}
      {% if "vimeo.com" in (entry.data.video_url or "") %}
      {% set thumb = vimeoThumbnails[entry.data.video_url] %}
      {% else %}
  {% set thumb = entry.data.video_url | thumbnailFromUrl %}
{% endif %}
      <a href="/motion-archive{{ entry.url }}" class="card"
        data-type="{{ entry.data.type }}"
        data-tags="{{ entry.data.tags | join(',') }}"
        data-tool="{{ entry.data.tool }}">
        <div class="thumb">
          {% if entry.data.status == "unavailable" %}
            <div class="thumb-unavailable">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              <span>No longer available</span>
            </div>
          {% elif thumb %}
            <img src="{{ thumb }}" alt="{{ entry.data.title }}" loading="lazy"
              onerror="this.parentElement.innerHTML='<div class=thumb-unavailable><span>Preview unavailable</span></div>'">
          {% else %}
          {% if entry.data.is_resource %}
            <div class="thumb-curriculum">
              <span class="thumb-curriculum-tool">{{ entry.data.creator }}</span>
              <span class="thumb-curriculum-label">reference</span>
            </div>
          {% elif entry.data.tool %}
            <div class="thumb-curriculum">
              <span class="thumb-curriculum-tool">{{ entry.data.tool }}</span>
              <span class="thumb-curriculum-label">official curriculum</span>
            </div>
          {% else %}
            <div class="thumb-unavailable"><span>No preview</span></div>
          {% endif %}
          {% endif %}
        </div>
        <div class="card-body">
          <div class="card-meta">
            <span class="type-badge type-{{ entry.data.type }}">{{ entry.data.type }}</span>
            {% if entry.data.level %}<span class="level-badge level-{{ entry.data.level }}">{{ entry.data.level }}</span>{% endif %}
            {% if entry.data.tool %}<span class="tool-badge">{{ entry.data.tool }}</span>{% endif %}
            <span class="meta-dot"></span>
            <span class="meta-text">{{ entry.data.year }}</span>
            <span class="meta-dot"></span>
            <span class="meta-text">{{ entry.data.creator }}</span>
          </div>
          <div class="card-title">{{ entry.data.title }}</div>
          <div class="card-tags">
            {% for tag in entry.data.tags %}
              <span class="card-tag">{{ tag }}</span>
            {% endfor %}
          </div>
          <div class="card-footer">
            <span class="card-license">CC BY-SA 4.0</span>
            {% set platform = entry.data.video_url | platformFromUrl %}
            {% if platform == "YouTube" %}
              <svg width="16" height="11" viewBox="0 0 24 17" fill="none"><rect width="24" height="17" rx="3.5" fill="#FF0000"/><polygon points="10,5 10,12 17,8.5" fill="white"/></svg>
            {% elif platform == "Vimeo" %}
              <span class="platform-text">Vimeo</span>
            {% endif %}
          </div>
        </div>
      </a>
    {% endif %}
  {% endfor %}
</div>

<div class="no-results" id="no-results" style="display:none">No entries for this combination yet.</div>

<script>
const cards = Array.from(document.querySelectorAll('.card'));
let activeType = 'all';
let activeTech = 'all';
let activeTool = 'all';

function updateCount(n) {
  const el = document.getElementById('count');
  let label = '<span>' + n + '</span> ' + (n === 1 ? 'entry' : 'entries');
  if (activeType !== 'all') label += ' · ' + activeType;
  if (activeTech !== 'all') label += ' · ' + activeTech;
  if (activeTool !== 'all') label += ' · ' + activeTool;
  el.innerHTML = label;
}

function cardMatches(card, type, tech, tool) {
  const matchType = type === 'all' || card.dataset.type === type;
  const matchTech = tech === 'all' || (card.dataset.tags || '').split(',').includes(tech);
  const matchTool = tool === 'all' || card.dataset.tool === tool;
  return matchType && matchTech && matchTool;
}

function filter() {
  let visible = 0;
  cards.forEach(card => {
    const show = cardMatches(card, activeType, activeTech, activeTool);
    card.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  updateCount(visible);
  document.getElementById('no-results').style.display = visible === 0 ? 'block' : 'none';
  updateAvailable();
}

function updateAvailable() {
  document.querySelectorAll('#type-filters .ftag').forEach(btn => {
    if (btn.dataset.type === 'all') return;
    const hasResults = cards.some(c => cardMatches(c, btn.dataset.type, activeTech, activeTool));
    btn.disabled = !hasResults;
  });
  document.querySelectorAll('#tech-filters .ftag').forEach(btn => {
    if (btn.dataset.tech === 'all') return;
    const hasResults = cards.some(c => cardMatches(c, activeType, btn.dataset.tech, activeTool));
    btn.disabled = !hasResults;
  });
  document.querySelectorAll('#tool-filters .ftag').forEach(btn => {
    if (btn.dataset.tool === 'all') return;
    const hasResults = cards.some(c => cardMatches(c, activeType, activeTech, btn.dataset.tool));
    btn.disabled = !hasResults;
  });
}

document.getElementById('type-filters').querySelectorAll('.ftag').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('type-filters').querySelectorAll('.ftag').forEach(b => b.classList.remove('active-type'));
    btn.classList.add('active-type');
    activeType = btn.dataset.type;
    filter();
  });
});

document.getElementById('tech-filters').querySelectorAll('.ftag').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('tech-filters').querySelectorAll('.ftag').forEach(b => b.classList.remove('active-tech'));
    btn.classList.add('active-tech');
    activeTech = btn.dataset.tech;
    filter();
  });
});

document.getElementById('tool-filters').querySelectorAll('.ftag').forEach(btn => {
  btn.addEventListener('click', () => {
    document.getElementById('tool-filters').querySelectorAll('.ftag').forEach(b => b.classList.remove('active-tool'));
    btn.classList.add('active-tool');
    activeTool = btn.dataset.tool;
    filter();
  });
});

filter();
</script>
