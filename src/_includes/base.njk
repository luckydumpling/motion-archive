<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}Motion Design Archive</title>
  <meta name="description" content="An open educational resource for motion design students.">
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
</head>
<body>
